# =========================================================================
# KONFIGURASI SUPABASE (SALIN KEDALAM FILE BARU BERNAMA .env)
# =========================================================================

# URL Project Supabase Anda (bisa didapatkan di Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key Project Supabase Anda (bisa didapatkan di Settings > API)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Email user Supabase Auth yang boleh masuk aplikasi.
# Buat user ini di Authentication > Users pada dashboard Supabase.
VITE_SUPABASE_AUTH_EMAIL=admin@example.com

# Fallback Local Mode jika tidak memakai Supabase.
# Buat nilainya dengan: npm run hash-password -- "sandi-anda"
# Catatan: hash ini hanya mencegah sandi asli terlihat di Inspect, bukan pengganti auth server.
VITE_APP_PASSWORD_SALT=your-random-salt
VITE_APP_PASSWORD_HASH=your-sha256-hash
